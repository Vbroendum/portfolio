# ── Copy this to .env on your server, fill in real values ─────────────────────

# App
GITHUB_USERNAME=GHUsername
DOMAIN=yourdomain.com
NODE_ENV=production
ALLOWED_ORIGIN=https://yourdomain.com

# Database
DB_ROOT_PASSWORD=change_me_root
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=change_me_db

# Auth — generate hash with:
# node -e "import('bcryptjs').then(b => b.default.hash('yourpassword', 12).then(console.log))"
JWT_SECRET=change_me_long_random_string
ADMIN_PASSWORD_HASH=$2b$12$...paste_bcrypt_hash_here...

# Email (SMTP — use your provider or a transactional service like Resend/Mailgun)
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_smtp_password
CONTACT_TO=yourmail@yourdomain.com
